# ──────────────────────────────────────────────────
# Telegram Bot Configuration
# ──────────────────────────────────────────────────
#
# This example is generated from the schema definitions.
# To use:  cp bot.env.example bot.env  (then fill in values)
# To regenerate:  uv run python scripts/gen_env_examples.py

# ── Telegram ──

# Bot Token (required)
# Authentication token for the Telegram bot
TELEGRAM_BOT_TOKEN=

# Allowed Chat IDs (required)
# Users authorized to trigger builds
ALLOWED_CHAT_IDS=

# Admin Contact
# Shown in "contact your admin" messages (e.g. "@john_doe")
# ADMIN_CONTACT=

# ── Git Repository ──

# Repository URL
# Git clone URL for the Flutter project
# GIT_REPO_URL=

# Access Token
# GitLab token with read_api scope (enables duplicate build detection)
# GIT_ACCESS_TOKEN=

# ── Jenkins Connection ──

# Jenkins URL (required)
# Internal Docker network URL (e.g. http://jenkins:8080)
JENKINS_URL=

# Jenkins User (required)
# Jenkins account with permission to trigger builds
JENKINS_USER=

# Jenkins API Token (required)
# Token for triggering pipeline builds
JENKINS_API_TOKEN=

# Pipeline Job Name
# Must match the pipeline job name in Jenkins
# JENKINS_JOB_NAME=flutter-build

# Repo Credentials ID
# Jenkins credential ID for cloning private repos (leave empty for public repos)
# JENKINS_CREDENTIALS_ID=

# ── Build Settings ──

# App Name
# Display name shown in bot messages (e.g. "MyApp")
# APP_NAME=

# Branch List
# Branches shown as quick-pick buttons (comma-separated)
# BRANCH_LIST=main

# Session Timeout
# Seconds before the branch picker expires
# SESSION_TTL=30

# Drive Folder Name
# Drive folder for APKs (auto-created if missing)
# DRIVE_FOLDER_NAME=

# Max Recent Builds
# Build history limit (0 = unlimited)
# MAX_RECENT_BUILDS=0

# Build Timeout
# Minutes before a build is considered timed out (0 = never)
# BUILD_TIMEOUT=30

# Bot Service URL
# Internal URL for this service (Jenkins POSTs results here, port is derived automatically)
# BOT_SERVICE_URL=http://tg-bot:9090
