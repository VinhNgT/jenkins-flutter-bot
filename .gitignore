# ==============================================================================
# Root .gitignore — OS, Editor, and Python patterns
# ==============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# Editors & IDEs
.idea/
.vscode/
*.swp
*.swo
*.swn
*~.nib
.project
.settings/
*.sublime-workspace
*.sublime-project

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/
.ruff_cache/

# Runtime data
data/

# Node.js / Frontend
node_modules/

# Vite build output — this directory is a build artifact, not source code.
# Source of truth is apps/tg-jenkins-bot/frontend/src/.
apps/tg-jenkins-bot/src/tg_jenkins_bot/webapp/
