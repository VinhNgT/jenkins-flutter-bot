# ==============================================================================
# Flutter Build Bot — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.

# ------------------------------------------------------------------------------
# Required — Telegram
# ------------------------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed to use the bot
# Use @userinfobot or @RawDataBot to find your chat ID
ALLOWED_CHAT_IDS=

# ------------------------------------------------------------------------------
# Required — Jenkins
# ------------------------------------------------------------------------------

# Jenkins server URL
JENKINS_URL=http://192.168.1.50:8080

# Jenkins bot user credentials (needs Job/Build + Job/Read permissions)
JENKINS_USER=build-bot
JENKINS_API_TOKEN=

# Jenkins job name for the Flutter build pipeline
JENKINS_JOB_NAME=flutter-build

# Stable bot-side job ID used for callback scoping (defaults to job name)
# JENKINS_JOB_ID=flutter-build

# ------------------------------------------------------------------------------
# Required — Google Drive OAuth client for config UI callback flow
# ------------------------------------------------------------------------------

# Get these from: https://console.cloud.google.com/apis/credentials
# Create an OAuth client ID (Web application) and authorize the config UI callback URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# Required — Bot Webhook
# ------------------------------------------------------------------------------

# Public/internal URL where this bot can be reached by Jenkins
# Jenkins will POST build results to this address
BOT_CALLBACK_HOST=http://192.168.1.50:9090

# Optional path to a JSON config file (takes precedence over env/.env)
# CONFIG_PATH=/app/config/bot.json

# Optional public URL for the config UI shown in Telegram guidance
# CONFIG_UI_URL=http://localhost:9000

# Optional path for the shared Google Drive OAuth token file
# BOT_OAUTH_TOKEN_PATH=/app/config/oauth.json

# Port for the webhook server (default: 9090)
BOT_WEBHOOK_PORT=9090

# ------------------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------------------

# Google Drive folder name for uploaded APKs (default: flutter-builds)
# DRIVE_FOLDER_NAME=flutter-builds
