# ==============================================================================
# Jenkins Flutter Bot Stack — Docker Compose Environment
# ==============================================================================
# Application configuration is managed through the config-ui dashboard.
# Populate bot and agent settings in the web dashboard after the stack starts.
#
# These env vars are only needed if you want to override docker-compose defaults
# or run containers outside of compose.
#
# ---- Agent (flutter-agent) ----
# JENKINS_URL=http://jenkins:8080
# JENKINS_AGENT_NAME=flutter-agent
# JENKINS_SECRET=<your-agent-secret>        # Required — get from Jenkins node config
# JENKINS_WEB_SOCKET=true                   # Use WebSocket (default) or set false for TCP
# JENKINS_TUNNEL=                           # Only needed with WEB_SOCKET=false
#
# ---- Bot (tg-bot) ----
# BOT_CALLBACK_HOST=http://tg-bot:9090      # Where Jenkins POSTs build results
# BOT_WEBHOOK_PORT=9090
# CONFIG_PATH=/config/bot/bot.json
# CONFIG_UI_URL=http://localhost:9000        # Host-facing URL for Telegram messages
