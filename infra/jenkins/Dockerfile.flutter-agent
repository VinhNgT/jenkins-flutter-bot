FROM jenkins/inbound-agent:jdk21

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip \
    && pip3 install --break-system-packages fastapi uvicorn python-dotenv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY agent-control.py /opt/agent-control.py

USER jenkins

ENTRYPOINT ["python3", "-m", "uvicorn", "agent-control:app", "--host", "0.0.0.0", "--port", "9091", "--app-dir", "/opt"]
