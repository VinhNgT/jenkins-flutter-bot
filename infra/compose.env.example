# ══════════════════════════════════════════════════
# Jenkins Flutter Bot — Configuration
# ══════════════════════════════════════════════════
# Edit this file, then run:  ./compose.sh prod up -d
# To regenerate template:    uv run python scripts/gen_env_examples.py

# ── Global Infrastructure ──

# Cloudflare Tunnel Token
# Used by cloudflared to expose the gateway to the internet
# CLOUDFLARE_TUNNEL_TOKEN=

# Image Tag
# Tag used when pulling images from GHCR (prod/edge modes)
# IMAGE_TAG=latest

# ── Service Hub (Infra) ──

# Agent Control Url
# AGENT_CONTROL_URL=None

# File Manager Url
# FILE_MANAGER_URL=None

# Build Manager Url
# BUILD_MANAGER_URL=None

# ── Telegram Bot ──

# Telegram

# Allowed Chat IDs
# List of chat IDs allowed to use the bot
# ALLOWED_CHAT_IDS=

# Admin Contact
# Shown to unauthorized users (e.g. '@username' or 'an admin')
# ADMIN_CONTACT=an admin

# Application

# App Name
# Name of the app being built (used in messages)
# APP_NAME=My App

# Build Options
# Mapping of display label → git branch (e.g. 'Stable Release' → 'main')
# BRANCHES={'Stable Release': 'main', 'Testing Version': 'develop'}

# Web App URL (required)
# Public HTTPS URL for the Telegram Web App (e.g. https://your-host/webapp/)
WEBAPP_URL=

# Mini App Short Name
# Short name of the Mini App registered with @BotFather via /newapp (e.g. 'builds'). When set, command buttons launch the app as a native Telegram Mini App panel in group chats via t.me/bot/shortname. Leave blank to fall back to a standard in-app browser button.
# WEBAPP_SHORT_NAME=

# Project

# GitHub Repository URL
# Public web URL of the repository. Used to add a GitHub link to the bot's welcome message.
# GITHUB_URL=

# Advanced

# Bot Service URL (required)
# Internal URL for this service's webhook endpoint
BOT_SERVICE_URL=

# Build Manager URL (required)
# Internal URL of the build-manager service
BUILD_MANAGER_URL=

# ── Agent Control ──

# Agent Connection

# Agent Name (required)
# Must match the node name in Jenkins
AGENT_NAME=

# Agent Secret (required)
# Authentication secret from the Jenkins node
SECRET=

# Jenkins URL (required)
# Same Jenkins controller URL used for the agent's inbound connection
JENKINS_URL=

# Advanced

# WebSocket Mode
# WebSocket recommended; disable only for direct TCP tunnels
# WEB_SOCKET=True

# Tunnel
# TCP tunnel endpoint (only when WebSocket is disabled)
# TUNNEL=

# VPN

# Enable VPN
# Connect to an OpenVPN server during builds (requires .ovpn file upload)
# VPN_ENABLED=False

# Max VPN Connection Time
# Auto-disconnect VPN after this many minutes (safety net)
# VPN_MAX_CONNECTED_MINUTES=45

# ── File Manager ──

# OAuth Credentials

# Drive Client ID
# OAuth 2.0 client ID from Google Cloud Console
# DRIVE_CLIENT_ID=

# Drive Client Secret
# OAuth 2.0 client secret
# DRIVE_CLIENT_SECRET=

# Storage Settings

# Drive Folder Name
# Drive folder for build artifacts (auto-created if missing)
# DRIVE_FOLDER_NAME=Flutter Builds

# Max Recent Builds
# Number of completed build records to retain (oldest are evicted)
# MAX_RECENT_BUILDS=5

# ── Build Manager ──

# Jenkins

# Jenkins User (required)
# Username for Jenkins API authentication
JENKINS_USER=

# Jenkins API Token (required)
# API token for Jenkins authentication
JENKINS_API_TOKEN=

# Jenkins Job Name (required)
# Name of the Jenkins pipeline job to trigger
JENKINS_JOB_NAME=

# Jenkins URL (required)
# Jenkins controller URL for API calls
JENKINS_URL=

# Advanced

# File Manager URL (required)
# Internal URL of the file-manager service
FILE_MANAGER_URL=

# Build Timeout (minutes)
# How long before a pending build is considered dead and its frontend is notified
# BUILD_TIMEOUT=30

# Poll Interval (seconds)
# How often to check Jenkins for build completion
# POLL_INTERVAL=10

# Artifact Pattern
# Glob pattern to match build artifacts in the Jenkins archive
# ARTIFACT_PATTERN=*.apk

# Internal Storage Directory
# Directory for persistent build state files
# BUILD_DATA_PATH=/app/data

# Agent Control URL
# Internal URL of the agent-control service for VPN management during builds
# AGENT_CONTROL_URL=
