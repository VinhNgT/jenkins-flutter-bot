# ──────────────────────────────────────────────────
# Build Manager Config
# ──────────────────────────────────────────────────
#
# This example is generated from the schema definitions.
# To use:  cp <name>.env.example <name>.env  (then fill in values)
# To regenerate:  uv run python scripts/gen_env_examples.py

# ── Jenkins ──

# Jenkins User (required)
# Username for Jenkins API authentication
JENKINS_USER=

# Jenkins API Token (required)
# API token for Jenkins authentication
JENKINS_API_TOKEN=

# Jenkins Job Name (required)
# Name of the Jenkins pipeline job to trigger
JENKINS_JOB_NAME=

# Jenkins URL (required)
# Jenkins controller URL for API calls
JENKINS_URL=

# ── Advanced ──

# File Manager URL (required)
# Internal URL of the file-manager service
FILE_MANAGER_URL=

# Max Recent Builds
# Maximum number of completed builds to keep. Older builds and their Drive files are automatically deleted.
# MAX_RECENT_BUILDS=3

# Build Timeout (minutes)
# How long before a pending build is considered dead and its frontend is notified
# BUILD_TIMEOUT=30

# Poll Interval (seconds)
# How often to check Jenkins for build completion
# POLL_INTERVAL=10

# Artifact Pattern
# Glob pattern to match build artifacts in the Jenkins archive
# ARTIFACT_PATTERN=*.apk

# Internal Storage Directory
# Directory for persistent build state files
# BUILD_DATA_PATH=/app/data
