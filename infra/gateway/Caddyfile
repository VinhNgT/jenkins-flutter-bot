# ── Global options ─────────────────────────────────────────────────
{
    # Process the rate_limit directive before reverse_proxy so that
    # over-limit requests are rejected without reaching the backend.
    order rate_limit before reverse_proxy

    servers {
        # Trust Docker bridge network IPs so that {remote_host} resolves
        # to the real client IP (via X-Forwarded-For from cloudflared)
        # instead of the container IP. Scoped to Docker's default bridge
        # pool — excludes 10.0.0.0/8 and 192.168.0.0/16.
        trusted_proxies static 172.16.0.0/12
    }
}

# ── tg-jenkins-bot (public, via Cloudflare tunnel) ────────────────
:80 {
    @bot_static {
        path /webapp/*.css /webapp/*.js
    }
    @bot_html {
        path /webapp /webapp/
    }
    @bot_api {
        path /api/webapp/*
    }
    @bot_routes {
        path /webapp* /api/webapp*
    }

    # ── Rate limiting ─────────────────────────────────────────────
    # Mutating endpoints (build trigger/cancel) — strict limit
    @webapp_mutate {
        path /api/webapp/trigger /api/webapp/cancel
    }
    rate_limit @webapp_mutate {
        zone webapp_mutate {
            key    {remote_host}
            events 10
            window 1m
        }
    }

    # Read endpoints — higher limit for normal polling
    @webapp_read {
        path /api/webapp/config /api/webapp/recent
    }
    rate_limit @webapp_read {
        zone webapp_read {
            key    {remote_host}
            events 30
            window 1m
        }
    }

    # SSE streams are NOT rate-limited — they are long-lived
    # connections, not repeated requests.

    # ── Handlers ──────────────────────────────────────────────────
    # Stream endpoints require immediate flushing
    handle /api/webapp/stream {
        header Cache-Control "no-store"
        reverse_proxy tg-jenkins-bot:9090 {
            flush_interval -1
        }
    }

    handle @bot_routes {
        # Tier 2: Versioned static assets — cache forever (?v=hash invalidates)
        header @bot_static Cache-Control "public, max-age=31536000, immutable"

        # Tier 1: HTML entry point — always revalidate to pick up new ?v= hashes
        header @bot_html Cache-Control "no-cache"

        # Tier 3: API responses — never cache operational data
        header @bot_api Cache-Control "no-store"

        reverse_proxy tg-jenkins-bot:9090
    }

    handle {
        respond "Not Found" 404
    }
}

# ── config-hub (admin dashboard, host-local only) ─────────────────
:9000 {
    # Brute-force protection — 30 req/min per client IP
    rate_limit {
        zone hub_admin {
            key    {remote_host}
            events 30
            window 1m
        }
    }

    @hub_static {
        path /static/*
    }
    @hub_html {
        path / /index.html
    }
    @hub_api {
        path /api/*
    }

    # Unversioned static assets — always revalidate (ETag/304)
    header @hub_static Cache-Control "no-cache"

    # HTML entry point — always revalidate to pick up changes
    header @hub_html Cache-Control "no-cache"

    # API responses — never cache config values, secrets, Drive status
    header @hub_api Cache-Control "no-store"

    # Stream endpoints require immediate flushing
    handle /api/services/stream {
        reverse_proxy config-hub:9000 {
            flush_interval -1
        }
    }

    handle {
        reverse_proxy config-hub:9000
    }
}
