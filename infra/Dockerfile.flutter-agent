# ==============================================================================
# Stage 1 — Download and prepare SDKs
# ==============================================================================
FROM jenkins/inbound-agent:jdk21 AS sdk-builder

USER root

# Build-only tools (won't be in the final image)
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl wget unzip ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# ---- Android SDK ----
ENV ANDROID_HOME=/opt/android-sdk
ENV PATH="${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${PATH}"

RUN mkdir -p ${ANDROID_HOME}/cmdline-tools \
    && cd ${ANDROID_HOME}/cmdline-tools \
    && wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip \
        -O cmdline-tools.zip \
    && unzip -q cmdline-tools.zip \
    && mv cmdline-tools latest \
    && rm cmdline-tools.zip \
    && (yes || true) | sdkmanager --licenses > /dev/null 2>&1 \
    && sdkmanager "platform-tools" \
        "platforms;android-31" "platforms;android-34" "platforms;android-35" "platforms;android-36" \
        "build-tools;34.0.0" "build-tools;35.0.0" \
        "ndk;28.2.13676358" \
        "cmake;3.22.1"

# ---- Flutter SDK ----
ENV FLUTTER_HOME=/opt/flutter
ENV PATH="${FLUTTER_HOME}/bin:${PATH}"

RUN git clone https://github.com/flutter/flutter.git -b stable --depth 1 ${FLUTTER_HOME}

# Pre-cache Flutter artifacts so the runtime image is ready to build immediately
RUN flutter precache --android \
    && flutter doctor --android-licenses 2>/dev/null || true

# Clean up to minimize COPY size
RUN rm -rf ${FLUTTER_HOME}/.git/refs/remotes \
    && rm -rf ${FLUTTER_HOME}/dev ${FLUTTER_HOME}/examples

# ==============================================================================
# Stage 2 — Minimal runtime image
# ==============================================================================
FROM jenkins/inbound-agent:jdk21

USER root

# uv for Python + dependency management (exception: kept in runtime
# because this image uses a non-Python base that lacks Python 3.12)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Runtime-only system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl zip unzip libglu1-mesa ca-certificates \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Copy pre-built SDKs from builder stage (--chown avoids a separate
# chown -R layer that would duplicate the entire SDK in Docker layers)
COPY --from=sdk-builder --chown=jenkins:jenkins /opt/android-sdk /opt/android-sdk
COPY --from=sdk-builder --chown=jenkins:jenkins /opt/flutter /opt/flutter

ENV ANDROID_HOME=/opt/android-sdk
ENV FLUTTER_HOME=/opt/flutter
ENV PATH="${FLUTTER_HOME}/bin:${ANDROID_HOME}/cmdline-tools/latest/bin:${ANDROID_HOME}/platform-tools:${PATH}"

# Reduce Gradle memory pressure — critical for x86_64 emulation on ARM64:
#   - Disable daemon: CI builds don't benefit from a persistent daemon process
#   - -Xmx4g: with daemon=false, the client JVM IS the build JVM, so set heap directly
#   - Disable VFS watching: inotify breaks under emulation (NativeException: error = 4)
ENV GRADLE_OPTS="-Xmx4g -Dorg.gradle.daemon=false -Dorg.gradle.vfs.watch=false"
ENV GRADLE_USER_HOME=/home/jenkins/.gradle

# Force Kotlin compiler to run in-process instead of spawning a separate daemon.
# The Kotlin daemon crashes on startup under x86_64 emulation (exit code 0).
RUN mkdir -p ${GRADLE_USER_HOME} \
    && echo "kotlin.compiler.execution.strategy=in-process" > ${GRADLE_USER_HOME}/gradle.properties

# Agent control API — uv manages Python since the base image lacks it.
# Install into /opt/uv-python (not /root/.local) so the jenkins runtime
# user can access it, and to avoid conflicts if the base image ever ships
# its own Python.
ENV UV_PYTHON_INSTALL_DIR=/opt/uv-python
WORKDIR /app
COPY pyproject.toml uv.lock ./
COPY libs/config-core/pyproject.toml libs/config-core/
COPY libs/config-core/src libs/config-core/src
COPY apps/agent-control/pyproject.toml apps/agent-control/
COPY apps/agent-control/src apps/agent-control/src
RUN uv sync --frozen --no-dev --no-editable --package agent-control --python 3.12
ENV PATH="/app/.venv/bin:${PATH}"

RUN mkdir -p /app/data \
    && chown -R jenkins:jenkins /app /opt/uv-python /home/jenkins/.gradle

USER jenkins

# Verify everything works
RUN flutter doctor

ENTRYPOINT ["agent-control"]
