# ==============================================================================
# Jenkins Flutter Bot Stack — Docker Compose Environment
# ==============================================================================
# These are Docker Compose interpolation variables only.
# App-level configuration lives in env/bot.env and env/agent.env.
#
# Generate example env files from schemas:
#   uv run python scripts/gen_env_examples.py
#
# For production without config-ui, use the "Export" tool in the
# config-ui dashboard (Tools → Config Transfer) to generate env files
# and oauth.json as a tarball, then extract into infra/.

# ---- Admin Bot (optional — leave empty to disable) ----
# ADMIN_BOT_TOKEN=
# ADMIN_CHAT_ID=

# ---- Production Image Tag (optional — defaults to latest) ----
# IMAGE_TAG=latest
