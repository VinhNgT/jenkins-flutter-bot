# ──────────────────────────────────────────────────
# Telegram Bot Config
# ──────────────────────────────────────────────────
#
# This example is generated from the schema definitions.
# To use:  cp <name>.env.example <name>.env  (then fill in values)
# To regenerate:  uv run python scripts/gen_env_examples.py

# ── Telegram ──

# Bot Token (required)
# Token from @BotFather
TELEGRAM_TOKEN=

# Allowed Chat IDs (required)
# Comma-separated list of chat IDs allowed to use the bot
ALLOWED_CHAT_IDS=

# Admin Contact
# Shown to unauthorized users (e.g. '@username' or 'an admin')
# ADMIN_CONTACT=an admin

# ── Application ──

# App Name
# Name of the app being built (used in messages)
# APP_NAME=My App

# Build Options
# Mapping of display label → git branch (e.g. 'Stable Release' → 'main')
# BRANCHES={'Stable Release': 'main', 'Testing Version': 'develop'}

# Web App URL (required)
# Public HTTPS URL for the Telegram Web App (e.g. https://your-host/webapp/)
WEBAPP_URL=

# Mini App Short Name
# Short name of the Mini App registered with @BotFather via /newapp (e.g. 'builds'). When set, command buttons launch the app as a native Telegram Mini App panel in group chats via t.me/bot/shortname. Leave blank to fall back to a standard in-app browser button.
# WEBAPP_SHORT_NAME=

# ── Project ──

# GitHub Repository URL
# Public web URL of the repository. Used to add a GitHub link to the bot's welcome message.
# GITHUB_URL=

# ── Advanced ──

# Bot Service URL (required)
# Internal URL for this service's webhook endpoint
BOT_SERVICE_URL=

# Build Manager URL (required)
# Internal URL of the build-manager service
BUILD_MANAGER_URL=

# File Manager URL (required)
# Internal URL of the file-manager service
FILE_MANAGER_URL=
