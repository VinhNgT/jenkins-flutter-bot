# ──────────────────────────────────────────────────
# File Manager Config
# ──────────────────────────────────────────────────
#
# This example is generated from the schema definitions.
# To use:  cp <name>.env.example <name>.env  (then fill in values)
# To regenerate:  uv run python scripts/gen_env_examples.py

# ── OAuth Credentials ──

# Drive Client ID
# OAuth 2.0 client ID from Google Cloud Console
# DRIVE_CLIENT_ID=

# Drive Client Secret
# OAuth 2.0 client secret
# DRIVE_CLIENT_SECRET=

# ── Storage Settings ──

# Drive Folder Name
# Drive folder for build artifacts (auto-created if missing)
# DRIVE_FOLDER_NAME=Flutter Builds

# Max Recent Builds
# Number of completed build records to retain (oldest are evicted)
# MAX_RECENT_BUILDS=5
