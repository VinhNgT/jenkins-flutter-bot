# ── General ──

# Bot Control Url
# BOT_CONTROL_URL=None

# Agent Control Url
# AGENT_CONTROL_URL=None

# File Manager Url
# FILE_MANAGER_URL=None

# Build Manager Url
# BUILD_MANAGER_URL=None

# Auth Username
# Username for Web UI Basic Authentication
# AUTH_USERNAME=None

# Auth Password
# Password for Web UI Basic Authentication
# AUTH_PASSWORD=None
